{
  "description": "skill-trace — syncs docs/skills.md to global skills log and auto-starts the viewer",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'command -v powershell >/dev/null 2>&1 && powershell -ExecutionPolicy Bypass -NonInteractive -File \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/sync-skills.ps1\"'; exit 0",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/sync-skills.sh\"",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -NonInteractive -WindowStyle Hidden -File \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/start-viewer.ps1\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/start-viewer.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
